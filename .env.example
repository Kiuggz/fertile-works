# =============================================================================
# Fertile Works Website & Portal - environment template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Vite only exposes vars prefixed with VITE_ to the browser bundle.
# =============================================================================

# --- Supabase (Phase A) -------------------------------------------------------
# Used by src/lib/supabase.ts for the Contact form 'contact-submission' Edge
# Function. Values: Supabase dashboard -> Settings -> API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- PMIS backend (Phase C - portal auth, not used yet) -----------------------
# Base URL of the deployed PMIS FastAPI backend that the tenant/landlord portal
# will call for OTP login and JWT-protected data (e.g. https://api.fertileworks.co.ke).
# VITE_API_BASE_URL=
