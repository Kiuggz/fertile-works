# Supabase — used by src/lib/supabase.ts for the Contact form Edge Function.
# Copy this file to .env and fill in real values from Supabase → Settings → API.
# Vite only exposes vars prefixed with VITE_ to the browser bundle.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
